{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "rrze-formular/form-wizard",
	"version": "0.0.2",
	"title": "RRZE Formular",
	"category": "widgets",
	"description": "Create a simple multi-step form wizard without HTML knowledge.",
	"icon": "feedback",
	"keywords": ["form", "contact", "wizard", "mail"],
	"attributes": {
		"template": {
			"type": "string",
			"default": "contact"
		},
		"formTitle": {
			"type": "string",
			"default": ""
		},
		"formDescription": {
			"type": "string",
			"default": ""
		},
		"recipientEmail": {
			"type": "string",
			"default": ""
		},
		"submitLabel": {
			"type": "string",
			"default": "Senden"
		},
		"successMessage": {
			"type": "string",
			"default": ""
		},
		"includeSsoInfo": {
			"type": "boolean",
			"default": true
		},
		"sendConfirmation": {
			"type": "boolean",
			"default": false
		},
		"fields": {
			"type": "array",
			"default": []
		}
	},
	"supports": {
		"html": false,
		"align": ["wide", "full"]
	},
	"textdomain": "rrze-formular",
	"editorScript": "file:../../build/form-wizard.js",
	"editorStyle": "rrze-formular-css",
	"viewScript": "rrze-formular-frontend",
	"style": "rrze-formular-css",
	"render": "file:./render.php"
}
